# ===========================================
# Fitness Analytics Pipeline — Environment
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Strava OAuth 2.0 ---
# Register at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Hevy API ---
# Requires Hevy PRO subscription
# Find your API key in the Hevy app settings
HEVY_API_KEY=

# --- DuckDB ---
DUCKDB_PATH=fitness.duckdb
